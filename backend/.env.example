APP_NAME=Norte Firme API
APP_ENV=development
API_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/nortefirme_db
# Para correr sin Docker puedes usar:
# DATABASE_URL=sqlite+pysqlite:///./nortefirme_dev.db

JWT_SECRET_KEY=change-this-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

ALLOW_ADMIN_REGISTRATION=true

CORS_ORIGINS=http://localhost:5173,https://nortefirme.com.mx

UPLOAD_BACKEND=local
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
