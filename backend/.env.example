APP_NAME=Norte Firme API
APP_ENV=development
API_PREFIX=/api/v1
DEBUG=true

DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/nortefirme_db

JWT_SECRET_KEY=change-this-secret
JWT_REFRESH_SECRET_KEY=change-this-refresh-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

ALLOW_ADMIN_REGISTRATION=true

CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://nortefirme.com.mx,https://www.nortefirme.com.mx

UPLOAD_BACKEND=local
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
PUBLIC_UPLOAD_BASE_URL=http://localhost:8000/uploads

LEAD_NOTIFICATION_EMAIL=contacto@nortefirme.com.mx
N8N_WEBHOOK_URL=

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_LEADS_PER_HOUR=5

S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=
